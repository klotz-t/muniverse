{
    "Name": "AE Decomposer Pipeline",
    "Description": "Configuration parameters for the Autoencoder-based EMG decomposition algorithm",

    "preProcessingConfig": [
        {
            "step": "bandpass",
            "high_pass": 20,
            "low_pass": 500,
            "method": "butter",
            "order": 2
        },
        {
            "step": "notch",
            "freqs": [50, 100, 150],
            "method": "butter",
            "order": 2
        },
        {
            "step": "time_window",
            "t_start": 0,
            "t_end": -1
        }
    ],

    "algorithmConfig": {
        "ext_fact": 10,
        "whitening_method": "ZCA",
        "whitening_backend": "ed",
        "whitening_reg": "auto",
        "spike_detection_exp": 2,
        "spike_detection_min_delay": 0.01,
        "latent_dim": null,
        "epochs": 150,
        "batch_size": 5000,
        "learning_rate": 0.008,
        "sparsity_p": 0.9,
        "sparsity_q": 1.8,
        "sparsity_eps": 1e-8,
        "lambda_sparsity": 1.0,
        "weight_decay": 0.0,
        "device": "cpu",
        "dtype": "float32",
        "random_seed": 1909,
        "shuffle_windows": true,
        "verbose": false
    },

    "postProcessingConfig": [
        {
            "step": "remove_duplicates",
            "max_shift": 0.01,
            "tolerance": 0.001,
            "threshold": 0.3,
            "quality_metric": "sil",
            "mode": "max"
        },
        {
            "step": "bad_source_detection",
            "quality_metric": "sil",
            "threshold": 0.85,
            "min_spikes": 10,
            "mode": "below"
        }  
    ]
}
